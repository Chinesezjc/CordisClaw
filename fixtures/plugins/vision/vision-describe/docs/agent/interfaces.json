{
  "plugin_id": "vision_vision_describe",
  "plugin_path": "vision/vision-describe",
  "plugin_version": "0.1.0",
  "abi_version": 2,
  "command_name": null,
  "nodes": [
    {
      "id": "vision_describe",
      "summary": "Download an image from URL and send to an OpenAI-compatible vision API (default: gpt-4o-mini) for AI-powered description. Requires OPENAI_API_KEY (or VISION_API_KEY) env var. Supports OPENAI_BASE_URL for custom endpoints.",
      "input_schema": {
        "properties": {
          "prompt": {
            "description": "Custom prompt for the vision model",
            "type": "string"
          },
          "url": {
            "description": "Image URL to analyze",
            "type": "string"
          }
        },
        "required": [
          "url"
        ],
        "type": "object"
      },
      "output_schema": {
        "properties": {
          "error": {
            "type": [
              "string",
              "null"
            ]
          },
          "model": {
            "type": [
              "string",
              "null"
            ]
          },
          "ok": {
            "type": "boolean"
          },
          "text": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "type": "object"
      },
      "side_effects": [
        "downloads image from URL",
        "sends to OpenAI-compatible vision API"
      ],
      "failure_modes": [
        "API key not set",
        "network error",
        "rate limited",
        "API quota exceeded",
        "image too large"
      ],
      "node_type": "task"
    }
  ],
  "system_hint": null
}