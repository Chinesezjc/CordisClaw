{
  "plugin_id": "vision",
  "plugin_path": "vision",
  "plugin_version": "0.1.0",
  "abi_version": 2,
  "command_name": null,
  "nodes": [
    {
      "id": "vision_ocr",
      "summary": "Download an image from URL and run tesseract OCR to extract text. Requires tesseract installed on the system. Default language: chi_sim+eng.",
      "input_schema": {
        "properties": {
          "lang": {
            "description": "Tesseract language code (default: chi_sim+eng)",
            "type": "string"
          },
          "node_id": {
            "const": "vision_ocr",
            "type": "string"
          },
          "url": {
            "description": "Image URL to OCR",
            "type": "string"
          }
        },
        "required": [
          "node_id",
          "url"
        ],
        "type": "object"
      },
      "output_schema": {
        "properties": {
          "error": {
            "type": [
              "string",
              "null"
            ]
          },
          "ok": {
            "type": "boolean"
          },
          "text": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "type": "object"
      },
      "side_effects": [
        "downloads image from URL",
        "runs tesseract OCR"
      ],
      "failure_modes": [
        "tesseract not installed",
        "network error",
        "language pack missing",
        "no text in image"
      ],
      "node_type": "task",
      "agent_accessible": false
    },
    {
      "id": "vision_describe",
      "summary": "Download an image from URL and send to an OpenAI-compatible vision API (default: gpt-4o-mini) for AI-powered description. Requires OPENAI_API_KEY (or VISION_API_KEY) env var. Supports OPENAI_BASE_URL for custom endpoints.",
      "input_schema": {
        "properties": {
          "node_id": {
            "const": "vision_describe",
            "type": "string"
          },
          "prompt": {
            "description": "Custom prompt for the vision model",
            "type": "string"
          },
          "url": {
            "description": "Image URL to analyze",
            "type": "string"
          }
        },
        "required": [
          "node_id",
          "url"
        ],
        "type": "object"
      },
      "output_schema": {
        "properties": {
          "error": {
            "type": [
              "string",
              "null"
            ]
          },
          "model": {
            "type": [
              "string",
              "null"
            ]
          },
          "ok": {
            "type": "boolean"
          },
          "text": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "type": "object"
      },
      "side_effects": [
        "downloads image from URL",
        "sends to OpenAI-compatible vision API"
      ],
      "failure_modes": [
        "API key not set",
        "network error",
        "rate limited",
        "API quota exceeded",
        "image too large"
      ],
      "node_type": "task",
      "agent_accessible": false
    }
  ],
  "system_hint": null
}