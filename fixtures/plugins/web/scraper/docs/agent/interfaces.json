{
  "plugin_id": "web_scraper",
  "plugin_path": "web/scraper",
  "plugin_version": "0.1.0",
  "abi_version": 2,
  "command_name": null,
  "nodes": [
    {
      "id": "web_scraper",
      "summary": "Search the web and optionally fetch each result's page content. Auto-selects backend by available API key: BRAVE_API_KEY preferred, falls back to BING_API_KEY. Returns up to max_results (default 3, max 5) with title, url, snippet, and fetched text.",
      "input_schema": {
        "type": "object",
        "required": ["query"],
        "properties": {
          "query": { "type": "string", "description": "Search query" },
          "max_results": { "type": "integer", "description": "Max results (default 3, max 5)" },
          "fetch_content": { "type": "boolean", "description": "Whether to fetch page content (default true)" }
        }
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "ok": { "type": "boolean" },
          "results": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "title": { "type": "string" },
                "url": { "type": "string" },
                "snippet": { "type": "string" },
                "text": { "type": ["string", "null"] },
                "text_truncated": { "type": "boolean" }
              }
            }
          },
          "error": { "type": ["string", "null"] }
        }
      },
      "side_effects": ["makes HTTP requests to Brave/Bing search API and target URLs"],
      "failure_modes": ["BRAVE_API_KEY and BING_API_KEY not set", "network unavailable", "rate limited", "no results found", "fetch timeout"],
      "node_type": "router",
      "agent_accessible": true
    }
  ],
  "system_hint": null
}
