{
  "plugin_id": "web",
  "plugin_path": "web",
  "plugin_version": "0.1.0",
  "abi_version": 2,
  "command_name": null,
  "nodes": [
    {
      "id": "web_search",
      "summary": "Search the web using DeepSeek, Brave, or Bing API. Auto-selects backend by available API key: DEEPSEEK_API_KEY preferred, then BRAVE_API_KEY, then BING_API_KEY. DeepSeek returns AI-summarised text; Brave/Bing return structured results (title/url/snippet).",
      "input_schema": {
        "properties": {
          "max_results": {
            "description": "Max results for structured backends (default 5, max 20); ignored by DeepSeek",
            "type": "integer"
          },
          "node_id": {
            "const": "web_search",
            "type": "string"
          },
          "query": {
            "description": "Search query",
            "type": "string"
          }
        },
        "required": [
          "node_id",
          "query"
        ],
        "type": "object"
      },
      "output_schema": {
        "properties": {
          "error": {
            "type": [
              "string",
              "null"
            ]
          },
          "ok": {
            "type": "boolean"
          },
          "results": {
            "description": "Structured results (Brave/Bing), null for DeepSeek",
            "items": {
              "type": "object"
            },
            "type": "array"
          },
          "text": {
            "description": "AI-summarised text (DeepSeek), null for structured backends",
            "type": [
              "string",
              "null"
            ]
          }
        },
        "type": "object"
      },
      "side_effects": [
        "makes HTTP request to DeepSeek /v1/chat, Brave Search API, or Bing API"
      ],
      "failure_modes": [
        "no API key set (DEEPSEEK_API_KEY, BRAVE_API_KEY, BING_API_KEY)",
        "network unavailable",
        "rate limited",
        "no results found"
      ],
      "node_type": "router",
      "agent_accessible": true
    },
    {
      "id": "web_fetch",
      "summary": "Fetch a web page and return plain-text content (HTML tags stripped). Max 8000 chars. Only http/https allowed.",
      "input_schema": {
        "properties": {
          "node_id": {
            "const": "web_fetch",
            "type": "string"
          },
          "url": {
            "description": "URL to fetch",
            "type": "string"
          }
        },
        "required": [
          "node_id",
          "url"
        ],
        "type": "object"
      },
      "output_schema": {
        "properties": {
          "error": {
            "type": [
              "string",
              "null"
            ]
          },
          "ok": {
            "type": "boolean"
          },
          "text": {
            "type": [
              "string",
              "null"
            ]
          },
          "truncated": {
            "type": "boolean"
          }
        },
        "type": "object"
      },
      "side_effects": [
        "makes HTTP GET request to the target URL"
      ],
      "failure_modes": [
        "invalid URL",
        "network timeout",
        "localhost/private IP blocked"
      ],
      "node_type": "router",
      "agent_accessible": true
    }
  ],
  "system_hint": null
}