{
  "plugin_id": "web",
  "plugin_path": "web",
  "plugin_version": "0.1.0",
  "abi_version": 2,
  "command_name": null,
  "nodes": [
    {
      "id": "web_search",
      "summary": "Search the web using DeepSeek Anthropic-compatible API. Returns structured results (title + URL per result) plus an AI summary. Use web_fetch to verify specific pages.",
      "input_schema": {
        "properties": {
          "node_id": {
            "const": "web_search",
            "type": "string"
          },
          "query": {
            "description": "Search query",
            "type": "string"
          }
        },
        "required": [
          "node_id",
          "query"
        ],
        "type": "object"
      },
      "output_schema": {
        "properties": {
          "error": {
            "type": [
              "string",
              "null"
            ]
          },
          "ok": {
            "type": "boolean"
          },
          "text": {
            "description": "Structured search results (numbered list with titles + URLs) + AI summary",
            "type": [
              "string",
              "null"
            ]
          }
        },
        "type": "object"
      },
      "side_effects": [
        "makes HTTP request to DeepSeek Anthropic-compatible endpoint with native web_search tool"
      ],
      "failure_modes": [
        "api key not configured",
        "network unavailable",
        "rate limited"
      ],
      "node_type": "router",
      "agent_accessible": true
    },
    {
      "id": "web_fetch",
      "summary": "Fetch a web page and return plain-text content (HTML tags stripped). Max 8000 chars. Only http/https allowed.",
      "input_schema": {
        "properties": {
          "node_id": {
            "const": "web_fetch",
            "type": "string"
          },
          "url": {
            "description": "URL to fetch",
            "type": "string"
          }
        },
        "required": [
          "node_id",
          "url"
        ],
        "type": "object"
      },
      "output_schema": {
        "properties": {
          "error": {
            "type": [
              "string",
              "null"
            ]
          },
          "ok": {
            "type": "boolean"
          },
          "text": {
            "type": [
              "string",
              "null"
            ]
          },
          "truncated": {
            "type": "boolean"
          }
        },
        "type": "object"
      },
      "side_effects": [
        "makes HTTP GET request to the target URL"
      ],
      "failure_modes": [
        "invalid URL",
        "network timeout",
        "localhost/private IP blocked"
      ],
      "node_type": "router",
      "agent_accessible": true
    }
  ],
  "system_hint": null
}