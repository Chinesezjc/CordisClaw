{
  "plugin_id": "web",
  "plugin_path": "web",
  "plugin_version": "0.1.0",
  "abi_version": 2,
  "command_name": null,
  "nodes": [
    {
      "id": "web_search",
      "summary": "Search the web using Brave or Bing API. Auto-selects backend by available API key: BRAVE_API_KEY preferred, falls back to BING_API_KEY. Returns up to max_results items with title, url, and snippet.",
      "input_schema": {
        "properties": {
          "max_results": {
            "description": "Max results (default 5, max 20)",
            "type": "integer"
          },
          "node_id": {
            "const": "web_search",
            "type": "string"
          },
          "query": {
            "description": "Search query",
            "type": "string"
          }
        },
        "required": [
          "node_id",
          "query"
        ],
        "type": "object"
      },
      "output_schema": {
        "properties": {
          "error": {
            "type": [
              "string",
              "null"
            ]
          },
          "ok": {
            "type": "boolean"
          },
          "results": {
            "items": {
              "type": "object"
            },
            "type": "array"
          }
        },
        "type": "object"
      },
      "side_effects": [
        "makes HTTP request to Brave Search API or Bing API"
      ],
      "failure_modes": [
        "BRAVE_API_KEY and BING_API_KEY not set",
        "network unavailable",
        "rate limited",
        "no results found"
      ],
      "node_type": "router",
      "agent_accessible": true
    },
    {
      "id": "web_fetch",
      "summary": "Fetch a web page and return plain-text content (HTML tags stripped). Max 8000 chars. Only http/https allowed.",
      "input_schema": {
        "properties": {
          "node_id": {
            "const": "web_fetch",
            "type": "string"
          },
          "url": {
            "description": "URL to fetch",
            "type": "string"
          }
        },
        "required": [
          "node_id",
          "url"
        ],
        "type": "object"
      },
      "output_schema": {
        "properties": {
          "error": {
            "type": [
              "string",
              "null"
            ]
          },
          "ok": {
            "type": "boolean"
          },
          "text": {
            "type": [
              "string",
              "null"
            ]
          },
          "truncated": {
            "type": "boolean"
          }
        },
        "type": "object"
      },
      "side_effects": [
        "makes HTTP GET request to the target URL"
      ],
      "failure_modes": [
        "invalid URL",
        "network timeout",
        "localhost/private IP blocked"
      ],
      "node_type": "router",
      "agent_accessible": true
    }
  ],
  "system_hint": null
}