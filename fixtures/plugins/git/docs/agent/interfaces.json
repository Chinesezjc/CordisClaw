      "summary": "Show git working tree diff (unified format). Use to review changes before committing.",
      "input_schema": {
        "properties": {
          "fixtures_root": {
            "description": "Path to the git repository root",
            "type": "string"
          },
          "node_id": {
            "const": "git_diff",
            "type": "string"
          },
          "path": {
            "description": "Optional: limit diff to a specific file or directory",
            "type": "string"
          },
          "staged": {
            "description": "Show staged changes only (default false)",
            "type": "boolean"
          }
        },
        "required": [
          "node_id",
          "fixtures_root"
        ],
        "type": "object"
      },
      "output_schema": {
        "properties": {
          "diff": {
            "type": [
              "string",
              "null"
            ]
          },
          "error": {
            "type": [
              "string",
              "null"
            ]
          },
          "ok": {
            "type": "boolean"
          }
        },
        "type": "object"
      },
      "side_effects": [
        "reads git working tree"
      ],
      "failure_modes": [
