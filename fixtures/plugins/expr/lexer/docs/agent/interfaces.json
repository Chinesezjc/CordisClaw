{
  "plugin_id": "expr_lexer",
  "plugin_path": "expr/lexer",
  "plugin_version": "0.1.0",
  "abi_version": 2,
  "nodes": [
    {
      "id": "expr_lexer",
      "summary": "Convert expression text into tokens.",
      "input_schema": {
        "type": "object",
        "required": [
          "expression"
        ],
        "properties": {
          "expression": {
            "type": "string"
          }
        }
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "tokens": {
            "type": "array"
          }
        }
      },
      "side_effects": [],
      "failure_modes": [
        "invalid number",
        "unexpected token"
      ]
    }
  ]
}
