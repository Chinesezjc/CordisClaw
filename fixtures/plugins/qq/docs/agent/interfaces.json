{
  "plugin_id": "qq",
  "plugin_path": "qq",
  "plugin_version": "0.1.0",
  "abi_version": 2,
  "command_name": "Qq",
  "nodes": [
    {
      "id": "qq_entry",
      "summary": "QQ adapter using the NoneBot (OneBot v11) protocol. Connect to a OneBot-compatible QQ client for sending messages.",
      "input_schema": {
        "properties": {
          "action": {
            "description": "configure | send | status | call",
            "type": "string"
          },
          "message": {
            "description": "Message text (for send)",
            "type": "string"
          },
          "payload": {
            "description": "Raw API call payload (for call)",
            "type": "object"
          },
          "target": {
            "description": "group:<id> or private:<id> (for configure / send)",
            "type": "string"
          },
          "url": {
            "description": "OneBot HTTP API base URL (for configure)",
            "type": "string"
          }
        },
        "required": [
          "action"
        ],
        "type": "object"
      },
      "output_schema": {
        "properties": {
          "action": {
            "type": "string"
          },
          "data": {},
          "message": {
            "type": [
              "string",
              "null"
            ]
          },
          "ok": {
            "type": "boolean"
          }
        },
        "type": "object"
      },
      "side_effects": [
        "requires OneBot HTTP server running"
      ],
      "failure_modes": [
        "no OneBot URL configured",
        "invalid target format",
        "message is empty",
        "OneBot API error",
        "unsupported action"
      ],
      "node_type": "router"
    }
  ]
}