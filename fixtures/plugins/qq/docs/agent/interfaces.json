{
  "plugin_id": "qq",
  "plugin_path": "qq",
  "plugin_version": "0.1.0",
  "abi_version": 2,
  "command_name": "Qq",
  "nodes": [
    {
      "id": "qq_entry",
      "summary": "QQ adapter using the NoneBot (OneBot v11) protocol. Connect to a OneBot-compatible QQ client for sending messages. Actions: configure, send, status, call.",
      "input_schema": {
        "properties": {
          "action": {
            "description": "configure | send | status | call",
            "type": "string"
          },
          "message": {
            "description": "Message text (for send)",
            "type": "string"
          },
          "payload": {
            "description": "Raw API call payload (for call)",
            "type": "object"
          },
          "target": {
            "description": "group:<id> or private:<id>",
            "type": "string"
          },
          "url": {
            "description": "OneBot HTTP API base URL (for configure)",
            "type": "string"
          }
        },
        "required": [
          "action"
        ],
        "type": "object"
      },
      "output_schema": {
        "properties": {
          "action": {
            "type": "string"
          },
          "data": {},
          "message": {
            "type": [
              "string",
              "null"
            ]
          },
          "ok": {
            "type": "boolean"
          }
        },
        "type": "object"
      },
      "side_effects": [
        "requires OneBot HTTP server running"
      ],
      "failure_modes": [
        "no OneBot URL configured",
        "invalid target format",
        "message is empty",
        "OneBot API error",
        "unsupported action"
      ],
      "node_type": "router",
      "agent_accessible": true
    },
    {
      "id": "qq_serve",
      "summary": "Start an HTTP server to receive OneBot v11 message events. Configure your OneBot client to POST events to http://<host>:<port>/onebot/event. Supports grayscale group whitelist.",
      "input_schema": {
        "properties": {
          "agent_session_id": {
            "description": "Optional: agent session ID for message routing",
            "type": "string"
          },
          "node_id": {
            "const": "qq_serve",
            "type": "string"
          },
          "payload": {
            "properties": {
              "allow_groups": {
                "description": "Group whitelist for grayscale testing",
                "items": {
                  "type": "string"
                },
                "type": "array"
              },
              "onebot_url": {
                "description": "OneBot HTTP API URL",
                "type": "string"
              },
              "port": {
                "description": "HTTP listen port (default 8080)",
                "type": "integer"
              }
            },
            "type": "object"
          }
        },
        "required": [
          "node_id"
        ],
        "type": "object"
      },
      "output_schema": {
        "properties": {
          "error": {
            "type": [
              "string",
              "null"
            ]
          },
          "message": {
            "type": [
              "string",
              "null"
            ]
          },
          "ok": {
            "type": "boolean"
          }
        },
        "type": "object"
      },
      "side_effects": [
        "starts an HTTP server thread",
        "listens on configured port"
      ],
      "failure_modes": [
        "port already in use",
        "OneBot client not configured to POST events"
      ],
      "node_type": "task",
      "agent_accessible": true
    },
    {
      "id": "qq_fetch_messages",
      "summary": "Fetch queued incoming QQ messages received by qq_serve. Returns all messages and drains the queue. Agent should poll this periodically.",
      "input_schema": {
        "properties": {
          "node_id": {
            "const": "qq_fetch_messages",
            "type": "string"
          }
        },
        "required": [
          "node_id"
        ],
        "type": "object"
      },
      "output_schema": {
        "properties": {
          "error": {
            "type": [
              "string",
              "null"
            ]
          },
          "messages": {
            "items": {
              "type": "object"
            },
            "type": "array"
          },
          "ok": {
            "type": "boolean"
          }
        },
        "type": "object"
      },
      "side_effects": [
        "drains the message queue"
      ],
      "failure_modes": [],
      "node_type": "router",
      "agent_accessible": false
    },
    {
      "id": "qq_send",
      "summary": "Send a message to a QQ group or private chat via OneBot v11 HTTP API. Supports reply/quote via reply_to.",
      "input_schema": {
        "properties": {
          "message": {
            "description": "Message text to send",
            "type": "string"
          },
          "node_id": {
            "const": "qq_send",
            "type": "string"
          },
          "reply_to": {
            "description": "Optional message_id to reply/quote",
            "type": "integer"
          },
          "target": {
            "description": "group:<id> or private:<id>",
            "type": "string"
          }
        },
        "required": [
          "node_id",
          "target",
          "message"
        ],
        "type": "object"
      },
      "output_schema": {
        "properties": {
          "error": {
            "type": [
              "string",
              "null"
            ]
          },
          "message": {
            "type": [
              "string",
              "null"
            ]
          },
          "ok": {
            "type": "boolean"
          }
        },
        "type": "object"
      },
      "side_effects": [
        "sends HTTP request to OneBot API"
      ],
      "failure_modes": [
        "no OneBot URL configured",
        "invalid target format",
        "message is empty"
      ],
      "node_type": "router",
      "agent_accessible": true
    },
    {
      "id": "qq_get_group_info",
      "summary": "Get group information (name, member count, etc.) via OneBot v11 get_group_info API.",
      "input_schema": {
        "properties": {
          "node_id": {
            "const": "qq_get_group_info",
            "type": "string"
          },
          "target": {
            "description": "group:<id>",
            "type": "string"
          }
        },
        "required": [
          "node_id",
          "target"
        ],
        "type": "object"
      },
      "output_schema": {
        "properties": {
          "data": {
            "description": "Raw OneBot get_group_info response",
            "type": "object"
          },
          "error": {
            "type": [
              "string",
              "null"
            ]
          },
          "message": {
            "type": [
              "string",
              "null"
            ]
          },
          "ok": {
            "type": "boolean"
          }
        },
        "type": "object"
      },
      "side_effects": [
        "calls OneBot get_group_info API"
      ],
      "failure_modes": [
        "no OneBot URL configured",
        "invalid target format",
        "group not found"
      ],
      "node_type": "router",
      "agent_accessible": true
    }
  ],
  "system_hint": "QQ GROUP CHAT MODE — you are running in a QQ group. Messages may be casual chat NOT directed at you.\nCRITICAL: Always decide whether the message is actually talking to YOU before responding.\nA message IS directed at you if: mentions \"机器人\", \"bot\", \"Cordis\"; asks a direct question; gives a command; has question words (how, why, what, 怎么, 为什么, 如何, 帮我).\nA message is NOT directed at you if: casual chat between members; emoji/sticker/single-word; talking about someone else; statements not asking for anything.\nIf NOT directed at you: use {\"action\":\"suspend\"}.\nIf directed at you: use {\"action\":\"respond\",\"message\":\"your reply here\"}.\n\nTo send a progress update or proactive message to the group you're talking to:\ninvoke_plugin(qq, qq_send, {\"node_id\":\"qq_send\",\"target\":\"group:<group_id>\",\"message\":\"<your message>\"})\nReplace <group_id> with the actual group ID from the incoming message.\nSend a brief progress message BEFORE any tool that may take more than a moment (build, test, search, etc.), and a follow-up when the tool completes.\n\nTo query group members: invoke_plugin(qq, qq_get_group_members, {\"node_id\":\"qq_get_group_members\",\"target\":\"group:<id>\"})\nTo proactively send to a group: invoke_plugin(qq, qq_send, {\"node_id\":\"qq_send\",\"target\":\"group:<id>\",\"message\":\"<text>\"})"
}